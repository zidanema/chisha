- `test_read_legacy_artifact_rejects_empty` (`""` raise)
- `test_read_legacy_artifact_rejects_symlink_escape` (symlink → root, resolve 后越界 raise)

#### B.8 `create_session / delete_session / enable_session`

```python
def create_session(*, name, sid=None, days=7, seed=42,
                   profile_label="profile@v2", origin="blank",
                   root=None, start_date=None, enabled=True) -> dict:
    sid = sid or _DEFAULT_SID
    _validate_sid(sid)
    if sid == _LEGACY_SID:
        raise ValueError(f"session_id {sid!r} is reserved")
    with _meta_lock(root):
        sp = _state_path(root, sid)
        if sp.exists():
            raise FileExistsError(f"session {sid} already exists")
        if isinstance(start_date, str):
            start_date = dt.date.fromisoformat(start_date)
        start_date = start_date or dt.date.today()
        new_state = {
            "sid": sid, "name": name, "seed": seed,
            "profile_label": profile_label, "origin": origin,
            "enabled": enabled,
            "current_date": start_date.isoformat(),
            "day_index": 1,
            "current_meal_idx": 0,
            "total_meals": days * 2,
            "history": [],
            "branch_from": None,
            "branch_from_meal_idx": None,
            "started_at_real": _now_real_iso(),
            "started_at_virtual": start_date.isoformat(),
            "last_l1_extraction": None,
        }
        _atomic_write_json(sp, new_state)
        if not _meta_path(root).exists():
            _atomic_write_json(_meta_path(root), {
                "schema_version": _SCHEMA_VERSION,
                "migrated_at": _now_real_iso(),
                "last_migration_at": _now_real_iso(),
                "legacy_files": [],
            })
        return new_state


def delete_session(sid, root=None) -> dict:
    _validate_sid(sid)
    with _meta_lock(root):
        d = _session_dir(root, sid)
        if d.exists():
            import shutil
            shutil.rmtree(d)
        return {"ok": True, "deleted_sid": sid}


def enable_session(sid="_default", root=None) -> dict:
    """Codex v2 #2: atomic enable (caller 调 init+copy 后调此 finalize)."""
    with _meta_lock(root):
        sp = _state_path(root, sid)
        if not sp.exists():
            raise FileNotFoundError(f"session {sid} not initialized")
        s = json.loads(sp.read_text("utf-8"))
        s["enabled"] = True
        _atomic_write_json(sp, s)
        return s
```

#### B.9 改写 `init / advance / reset / disable / record_l1_extraction`

`init(start_date=None, *, root=None, copy_real_data=False, session_id=None) -> dict`:
```python
def init(start_date=None, *, root=None, copy_real_data=False, session_id=None):
    sid = session_id or _DEFAULT_SID
    _validate_sid(sid)
    if sid == _LEGACY_SID:
        raise ValueError(f"session_id {sid!r} is reserved")
    with _meta_lock(root):
        # auto-migrate (idempotent, in-lock)
        _migrate_legacy_locked(root)
        sp = _state_path(root, sid)
        sp.parent.mkdir(parents=True, exist_ok=True)
        if isinstance(start_date, str):
            start_date = dt.date.fromisoformat(start_date)
        start_date = start_date or dt.date.today()
        # D-077 init 重置语义: 覆盖既有 state
        new_state = {
            "sid": sid, "name": ("默认 session" if sid == _DEFAULT_SID else sid),
            "seed": 42, "profile_label": "profile@v2",
            "origin": "real_snapshot" if copy_real_data else "blank",
            # Codex v2 #2: copy_real_data 时 enabled=False, caller 调
            # enable_session 完结. is_enabled() False → data_root 走 prod
            # → 不暴露空桶给 reader.
            "enabled": not copy_real_data,
            "current_date": start_date.isoformat(),
            "day_index": 1,
            "current_meal_idx": 0, "total_meals": 14,
            "history": [],
            "branch_from": None, "branch_from_meal_idx": None,
            "started_at_real": _now_real_iso(),
            "started_at_virtual": start_date.isoformat(),
            "copy_real_data": copy_real_data,
            "last_l1_extraction": None,
        }
        _atomic_write_json(sp, new_state)
        if not _meta_path(root).exists():
            _atomic_write_json(_meta_path(root), {
                "schema_version": _SCHEMA_VERSION,
                "migrated_at": _now_real_iso(),
                "last_migration_at": _now_real_iso(),
                "legacy_files": [],
            })
        return new_state
```

`advance(days, *, root, session_id=None)`: sid 默认 `_default`. **解除 S-04 destructive reject 限制** (S-05 真支持). 持 `_meta_lock`. 读改写 `sessions/{sid}/state.json`.

`reset(*, root, session_id=None)`:
- sid None / `_default`: 删 `logs/sandbox/` 全部 (D-077 兼容; 持锁)
- sid 非 default: 只 rmtree `sessions/{sid}/` (持锁)

`disable(*, root, session_id=None)`:
- sid None / `_default`: `_default/state.json.enabled=False` (持锁; `_meta.json` 保留, `is_enabled()` False)
- sid 非 default: per-session enabled=False

`record_l1_extraction(status, *, based_on_meals=None, error=None, trigger="day_advance", root=None, session_id=None)`:
- 写 `sessions/{sid}/state.json.last_l1_extraction = {at, status, based_on_meals, error, trigger}`
- 持 `_meta_lock`

