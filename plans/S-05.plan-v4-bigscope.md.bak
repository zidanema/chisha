### Stage B — sandbox.py per-session state + multi-session API + atomic migrate_legacy

**目标**: 引入 `_meta.json` + `_meta_lock` (fcntl) + multi-session API + migrate_legacy. data_root 仍用 `is_enabled` 决定走 sandbox (Stage A 不变). 新 `has_sandbox_layout` API 仅供 inspect / `list_sessions` 用.

#### B.1 路径常量 + helper

```python
import fcntl
import os
from contextlib import contextmanager

_META_REL = "logs/sandbox/_meta.json"
_META_LOCK_REL = "logs/.sandbox_meta.lock"  # v4 Codex #1: 移出 logs/sandbox/ 防 reset 删 lock 文件竞态
_SESSIONS_REL = "logs/sandbox/sessions"
_LEGACY_SID = "_legacy"
_SCHEMA_VERSION = 2

def _meta_path(root): return _resolve_root(root) / _META_REL
def _meta_lock_path(root): return _resolve_root(root) / _META_LOCK_REL
def _session_dir(root, sid): return _resolve_root(root) / _SESSIONS_REL / sid

def _state_path(root=None, sid="_default"):
    return _session_dir(root, sid) / "state.json"


def _atomic_write_json(path: Path, data: dict) -> None:
    """Codex v2 #4: tmp + os.replace 原子写, 防 crash 损坏 metadata."""
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2),
                   encoding="utf-8")
    os.replace(tmp, path)


@contextmanager
def _meta_lock(root):
    """跨进程 sandbox metadata 锁 (fcntl.flock).

    Codex v2 #4 + #5: 所有公开 mutator 自身持锁; 私有 _xxx_locked helper
    假定 caller 已持锁, 不再嵌套.
    """
    lock_p = _meta_lock_path(root)
    lock_p.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(lock_p, os.O_CREAT | os.O_RDWR, 0o644)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX)
        yield
    finally:
        try:
            fcntl.flock(fd, fcntl.LOCK_UN)
        finally:
            os.close(fd)
```

#### B.2 `has_sandbox_layout(root) -> bool` (inspect only, 不影响 path routing)

```python
def has_sandbox_layout(root=None):
    """S-05: True 当 _meta.json 存在. 供 list_sessions / inspect 用 ——
    **不**影响 data_root path routing (那由 is_enabled 控制).
    """
    return _meta_path(root).exists()
```

#### B.3 `is_enabled(root, session_id=None) -> bool` (D-077 语义, data_root 用)

```python
def is_enabled(root=None, *, session_id=None):
    """S-05: 与 D-077 语义一致 — default session state.enabled=True 才 True.

    Codex v2 #1: data_root 用此函数决定走 sandbox; disable 后立刻降回 prod,
    不读空 sandbox 桶.
    """
    del session_id
    s = state(root, session_id=_DEFAULT_SID)
    return bool(s.get("enabled"))
```

`state(root, session_id=None)`: 读 `sessions/{sid}/state.json`, 文件不存在/损坏 → `{enabled: False}`. 不持锁 (读操作).

#### B.4 `_migrate_legacy_locked(root) -> dict` (private, caller 持锁)

```python
def _migrate_legacy_locked(root, *, dry_run=False):
    """老 flat layout → sessions/_legacy/. 持锁 caller 调.

    Codex v1 #1 + #3 + v2 #4: raw state.json 原样挪, __migration.json
    独立元数据 (atomic write), 主动扫顶层 repair partial, _meta.json 落.

    返 {migrated, files_moved, dry_run?, reason?}
    """
    sandbox_dir = _resolve_root(root) / "logs" / "sandbox"
    if not sandbox_dir.exists():
        return {"migrated": False, "reason": "no sandbox dir",
                "files_moved": []}
    candidates = []
    for entry in sandbox_dir.iterdir():
        if entry.name in {"sessions", "_meta.json", "_meta.lock"}:
            continue
        candidates.append(entry)
    meta_exists = _meta_path(root).exists()
    if not candidates and meta_exists:
        return {"migrated": False, "reason": "already migrated",
                "files_moved": []}
    if not candidates and not meta_exists:
        if not dry_run:
            _atomic_write_json(_meta_path(root), {
                "schema_version": _SCHEMA_VERSION,
                "migrated_at": _now_real_iso(),
                "last_migration_at": _now_real_iso(),
                "legacy_files": [],
            })
        return {"migrated": False, "reason": "no legacy data",
                "files_moved": []}
    if dry_run:
        return {"migrated": False, "dry_run": True,
                "plan": {"target": str(sandbox_dir / "sessions" / _LEGACY_SID),
                         "files_to_move": [str(c.relative_to(_resolve_root(root)))
                                           for c in candidates]}}
    import shutil
    legacy_dir = sandbox_dir / "sessions" / _LEGACY_SID
    legacy_dir.mkdir(parents=True, exist_ok=True)
    moved = []
    for c in candidates:
        target = legacy_dir / c.name
        if target.exists():
            n = 1
            while (legacy_dir / f"{c.name}.bak.{n}").exists():
                n += 1
            target = legacy_dir / f"{c.name}.bak.{n}"
        shutil.move(str(c), str(target))
        moved.append({"src": str(c.relative_to(_resolve_root(root))),
                      "dst": str(target.relative_to(_resolve_root(root)))})
    # __migration.json (atomic merge)
    mig_p = legacy_dir / "__migration.json"
    existing_mig = {}
    if mig_p.exists():
        try:
            existing_mig = json.loads(mig_p.read_text("utf-8"))
        except (OSError, json.JSONDecodeError):
            existing_mig = {}
    _atomic_write_json(mig_p, {
        "sid": _LEGACY_SID,
        "origin": "legacy",
        "readonly": True,
        "schema_version_from": 1,
        "migrated_at": existing_mig.get("migrated_at") or _now_real_iso(),
        "last_migration_at": _now_real_iso(),
        "source_files": (existing_mig.get("source_files") or []) + moved,
    })
    # _meta.json (atomic merge)
    meta_existing = {}
    if meta_exists:
        try:
            meta_existing = json.loads(_meta_path(root).read_text("utf-8"))
        except (OSError, json.JSONDecodeError):
            meta_existing = {}
    _atomic_write_json(_meta_path(root), {
        "schema_version": _SCHEMA_VERSION,
        "migrated_at": meta_existing.get("migrated_at") or _now_real_iso(),
        "last_migration_at": _now_real_iso(),
        "legacy_files": (meta_existing.get("legacy_files") or []) + moved,
    })
    return {"migrated": True, "files_moved": moved,
            "meta_path": str(_meta_path(root))}


def migrate_legacy(root=None, *, dry_run=False):
    """public API. 持 _meta_lock."""
    with _meta_lock(root):
        return _migrate_legacy_locked(root, dry_run=dry_run)
```

#### B.5 `rollback_legacy_migration(root, *, dry_run=False)` (Codex v2 #8)

```python
def rollback_legacy_migration(root=None, *, dry_run=False):
    """走 _legacy/__migration.json.source_files 反向 mv. 持 _meta_lock.

    fail-loud 当: manifest 不存在 / 损坏 / src 已存在 / dst 缺失.
    """
    with _meta_lock(root):
        r = _resolve_root(root)
        mig_p = r / _SESSIONS_REL / _LEGACY_SID / "__migration.json"
        if not mig_p.exists():
            raise FileNotFoundError(
                f"no __migration.json at {mig_p}, nothing to rollback"
            )
        try:
            m = json.loads(mig_p.read_text("utf-8"))
        except json.JSONDecodeError as e:
            raise ValueError(f"__migration.json corrupt: {e!r}")
        source_files = m.get("source_files") or []
        if not source_files:
            return {"rolled_back": 0, "reason": "empty manifest"}
        plan = []
        for entry in source_files:
            cur = r / entry["dst"]
            old = r / entry["src"]
            if not cur.exists():
                raise FileNotFoundError(
                    f"missing _legacy file {cur} (manifest says it came from {old})"
                )
            if old.exists():
                raise FileExistsError(
                    f"refusing to overwrite {old} (already restored?)"
                )
            plan.append((cur, old))
        if dry_run:
            return {"rolled_back": 0, "dry_run": True,
                    "plan": [(str(s), str(d)) for s, d in plan]}
        for cur, old in plan:
            old.parent.mkdir(parents=True, exist_ok=True)
            cur.rename(old)
        # 清 manifest + _meta.json
        mig_p.unlink()
        meta_p = _meta_path(root)
        if meta_p.exists():
            meta_p.unlink()
        # 删空的 _legacy/
        leg_dir = r / _SESSIONS_REL / _LEGACY_SID
        if leg_dir.exists() and not any(leg_dir.iterdir()):
            leg_dir.rmdir()
        return {"rolled_back": len(plan), "files_restored": [str(d) for _, d in plan]}
```

#### B.6 `list_sessions(root=None) -> list[dict]` (Codex v2 #3)

```python
def list_sessions(root=None):
    """合并 state.json + __migration.json. _legacy 桶强制 enabled=False."""
    d = _resolve_root(root) / _SESSIONS_REL
    if not d.exists(): return []
    out = []
    for sub in sorted(d.iterdir()):
        if not sub.is_dir(): continue
        sp = sub / "state.json"
        mig = sub / "__migration.json"
        item = {"sid": sub.name}
        if sp.exists():
            try:
                s = json.loads(sp.read_text("utf-8"))
                if isinstance(s, dict): item.update(s)
            except (OSError, json.JSONDecodeError):
                item["enabled"] = False
                item["error"] = "state.json corrupt"
        if mig.exists():
            try:
                m = json.loads(mig.read_text("utf-8"))
                if isinstance(m, dict):
                    item["origin"] = m.get("origin", item.get("origin"))
                    item["readonly"] = m.get("readonly", False)
                    item["migrated_at"] = m.get("migrated_at")
            except (OSError, json.JSONDecodeError):
                pass
        # Codex v2 #3: _legacy 桶 list 派生强制 enabled=False (磁盘 raw 不动)
        if sub.name == _LEGACY_SID:
            item["enabled"] = False
            item["readonly"] = True
        item.setdefault("sid", sub.name)
        out.append(item)
    return out
```

#### B.7 `read_legacy_artifact(rel, root=None) -> Path` (Codex v2 #10 / v3 #2 traversal)

```python
def read_legacy_artifact(rel, root=None):
    """显式只读 helper, 返 sessions/_legacy/{rel} 绝对路径.

    不通过 data_root (避免 _legacy 进 path helper 通用流). caller 自己 read.

    v3 #2 traversal 校验:
    - rel 必须 str, 非空, 不以 / 开头 (拒绝 absolute)
    - rel 不能含 '..' segment
    - 拼接后 Path.resolve() 必须仍在 sessions/_legacy/ 子树
    - 不允许写 (此函数只构造 read 路径; caller open with 'r')
    """
    if not isinstance(rel, str) or not rel:
        raise ValueError(f"read_legacy_artifact: rel must be non-empty str, got {rel!r}")
    if rel.startswith("/") or rel.startswith("\\"):
        raise ValueError(f"read_legacy_artifact: rel must be relative, got {rel!r}")
    parts = Path(rel).parts
    if ".." in parts:
        raise ValueError(f"read_legacy_artifact: rel must not contain '..', got {rel!r}")
    legacy_root = (_resolve_root(root) / _SESSIONS_REL / _LEGACY_SID).resolve()
    target = (legacy_root / rel).resolve()
    try:
        target.relative_to(legacy_root)
    except ValueError:
        raise ValueError(
            f"read_legacy_artifact: rel resolves outside _legacy sandbox: {target}"
        )
    return target
```

